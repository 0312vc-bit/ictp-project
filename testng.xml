<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="ICTP Continuous Test Suite" verbose="1">
    <listeners>
        <listener class-name="com.ictp.utils.ReportListener"/>
    </listeners>

    <test name="UI Automation Tests">
        <classes>
            <class name="com.ictp.tests.ui.LoginUiTest"/>
        </classes>
    </test>

    <test name="API Automation Tests">
        <classes>
            <class name="com.ictp.tests.api.HealthApiTest"/>
        </classes>
    </test>
</suite>
